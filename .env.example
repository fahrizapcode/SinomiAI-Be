# Database connection string (Supabase / PostgreSQL)
DATABASE_URL=your_supabase_postgresql_connection_string

# Secret key for JWT token signatures
JWT_SECRET=your_jwt_secret_key

# Port to run the server on (Railway sets this dynamically, default is 5000)
PORT=5000

# Google Gemini API Key for LLM generations
GEMINI_API_KEY=your_gemini_api_key

# Production Frontend URL (for CORS allowance)
CLIENT_URL=https://your-app.vercel.app
